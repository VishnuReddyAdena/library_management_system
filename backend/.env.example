# MongoDB Connection (leave blank to use in-memory database)
MONGO_URI="mongodb+srv://<db_user>:<db_password>@<cluster_address>/librarydb?retryWrites=true&w=majority"
MONGODB_URI="mongodb+srv://<db_user>:<db_password>@<cluster_address>/librarydb?retryWrites=true&w=majority"

# Nodemailer SMTP Configuration for Verification Emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# Optional: Twilio Configuration for Phone Verification
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="your_twilio_phone_number"
